{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["api/**/*", "artifacts/api-server/src/**/*"],
  "exclude": ["node_modules", "artifacts/vcf-registration", "artifacts/mockup-sandbox"]
}
